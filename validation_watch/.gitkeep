# validation_watch/ - Inactive literature/proxy candidate review artifacts
#
# This directory holds formatted candidate reports generated by
# scripts/validation_watch.py for human review only.
#
# All entries MUST carry:
#   review_state: "needs_review"
#   active_in_penalty_model: false
#
# These are NOT ingested into active failure database or penalty model.
# Prototype collection/formatting tool only. No auto-validation.
